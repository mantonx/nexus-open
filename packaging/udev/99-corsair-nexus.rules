# udev rules for Corsair iCUE Nexus
# This allows non-root users in the plugdev group to access the device

# Corsair iCUE Nexus (VID: 0x1b1c, PID: 0x1b8e)
SUBSYSTEM=="usb", ATTRS{idVendor}=="1b1c", ATTRS{idProduct}=="1b8e", MODE="0666", GROUP="plugdev", TAG+="uaccess"

# Alternative for systems using 'input' group
SUBSYSTEM=="usb", ATTRS{idVendor}=="1b1c", ATTRS{idProduct}=="1b8e", MODE="0666", GROUP="input", TAG+="uaccess"
