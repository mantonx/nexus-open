[Unit]
Description=Nexus Open - iCUE Nexus Display Controller
Documentation=https://github.com/mantonx/nexus-next
After=graphical.target

[Service]
Type=simple
ExecStart=/usr/bin/nexus-open
Restart=on-failure
RestartSec=5s

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.config/nexus-open

# Resource limits
MemoryMax=100M
CPUQuota=20%

[Install]
WantedBy=default.target
