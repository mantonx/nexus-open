#!/bin/bash
set -e

# Reload udev rules in case they changed.
if command -v udevadm > /dev/null 2>&1; then
    udevadm control --reload-rules 2>/dev/null || true
fi

# Update desktop and icon caches if available.
command -v update-desktop-database > /dev/null 2>&1 && \
    update-desktop-database -q /usr/share/applications || true
command -v gtk-update-icon-cache > /dev/null 2>&1 && \
    gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor || true

# Restart the service for every active user session.
if command -v loginctl > /dev/null 2>&1; then
    while IFS= read -r uid; do
        systemctl --user -M "${uid}@.host" restart nexus-open.service 2>/dev/null || true
    done < <(loginctl list-sessions --no-legend 2>/dev/null | awk '{print $2}' | sort -u)
fi
