[Desktop Entry]
Type=Application
Name=Nexus Open
Comment=iCUE Nexus companion — display monitor and configuration
Exec=nexus-open --tray
Icon=nexus-open
Terminal=false
Categories=Utility;System;HardwareSettings;
Keywords=corsair;nexus;icue;monitor;display;
StartupNotify=true
StartupWMClass=io.nexus.open

[Desktop Action Show]
Name=Show Window
Exec=nexus-open --show
